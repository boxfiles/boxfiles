#!/usr/bin/env bash
set -euo pipefail

repo_name="boxfiles.github.io"
src="${MOON_PROJECT_ROOT}/dist/public"
branch="main"
tmp="$(mktemp -d)"

cleanup() {
  rm -rf "${tmp}"
}
trap cleanup EXIT

# Use the GitHub Actions bot identity in CI, but allow local overrides.
git config user.name "${GIT_AUTHOR_NAME:-github-actions[bot]}"
git config user.email "${GIT_AUTHOR_EMAIL:-41898282+github-actions[bot]@users.noreply.github.com}"

# Resolve the GitHub owner from CI first, then from the current repo.
owner="${GITHUB_REPOSITORY_OWNER:-}"
if [ -z "${owner}" ]; then
  owner="$(gh repo view --json owner --jq .owner.login)"
fi
repo="${owner}/${repo_name}"

# Create the Pages repo if it does not exist yet.
if ! gh repo view "${repo}" >/dev/null 2>&1; then
  gh repo create "${repo}" --public --description "Boxfiles documentation site"
fi

# Clone the Pages repo into a throwaway folder so the source checkout stays untouched.
gh repo clone "${repo}" "${tmp}"

# Publish from the root of main, even when the repo was just created empty.
if git -C "${tmp}" rev-parse --verify HEAD >/dev/null 2>&1; then
  git -C "${tmp}" switch "${branch}" 2>/dev/null || git -C "${tmp}" switch -C "${branch}"
else
  git -C "${tmp}" switch --orphan "${branch}"
fi

# Replace everything in the Pages repo root with the freshly built static site.
find "${tmp}" -mindepth 1 -maxdepth 1 ! -name .git -exec rm -rf {} +
cp -R "${src}"/. "${tmp}"/

# Keep GitHub Pages from running Jekyll over the generated files.
touch "${tmp}/.nojekyll"

# Commit and push only when the generated site changed.
git -C "${tmp}" add -A
if git -C "${tmp}" diff --cached --quiet; then
  echo "No docs changes."
else
  git -C "${tmp}" commit -m "publish docs"
  git -C "${tmp}" push origin "HEAD:${branch}"
fi

# Configure GitHub Pages to serve from the repo root on main.
if gh api "repos/${repo}/pages" >/dev/null 2>&1; then
  gh api --method PUT "repos/${repo}/pages" -f "source[branch]=${branch}" -f 'source[path]=/' >/dev/null
else
  gh api --method POST "repos/${repo}/pages" -f "source[branch]=${branch}" -f 'source[path]=/' >/dev/null
fi
